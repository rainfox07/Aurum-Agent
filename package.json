{
  "name": "aurum-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "start": "next start",
    "build": "next build",
    "lint": "eslint src tests --ext .ts,.tsx",
    "typecheck": "rm -rf .next/types .next-dev/types tsconfig.tsbuildinfo && tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@auth/drizzle-adapter": "^1.11.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
